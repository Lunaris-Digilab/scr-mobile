# Edge Function secrets — set these in the Supabase edge-runtime / `functions`
# service environment (in Coolify for self-hosted Supabase), NOT in the mobile
# app's .env and NEVER as an EXPO_PUBLIC_* var (those ship in the client bundle).
# Never commit the real value.

# Anthropic API key used by the extract-product function (Claude vision).
ANTHROPIC_API_KEY=

# Provided automatically by the Supabase stack — listed for reference only:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
